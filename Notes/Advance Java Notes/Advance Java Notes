MAPSTRUCT
==========

- MapStruct is used for object mapping.
- Converts Entity <-> DTO automatically.
- Reduces boilerplate code.
- Generates implementation at compile time.
- Faster than reflection-based mapping.


WHY USE MAPSTRUCT ?
===================
Without MapStruct:
------------------
Manual setter/getter mapping required.

With MapStruct:
---------------
Automatic mapping using interface.


DEPENDENCY
==========

<dependency>
    <groupId>org.mapstruct</groupId>
    <artifactId>mapstruct</artifactId>
    <version>1.5.5.Final</version>
</dependency>

<dependency>
    <groupId>org.mapstruct</groupId>
    <artifactId>mapstruct-processor</artifactId>
    <version>1.5.5.Final</version>
    <scope>provided</scope>
</dependency>


ENTITY
======

public class User {

    private Long id;
    private String name;
    private String city;
}


DTO
===

public class UserDTO {

    private Long id;
    private String name;
    private String city;
}


MAPPER
======

@Mapper(componentModel = "spring")
public interface UserMapper {

    UserDTO toDto(User user);

    User toEntity(UserDTO dto);
}


USAGE
=====

@Autowired
private UserMapper mapper;

UserDTO dto = mapper.toDto(user);


@Generated implementation created automatically.


@MAPPING ANNOTATION
===================

- Used when field names are different.

Example
=======

public class User {

    private String fullName;
}

public class UserDTO {

    private String name;
}


Mapper:
-------

@Mapper(componentModel = "spring")
public interface UserMapper {

    @Mapping(source = "fullName",
             target = "name")
    UserDTO toDto(User user);
}


MULTIPLE MAPPINGS
=================

@Mappings({
    @Mapping(source = "fullName", target = "name"),
    @Mapping(source = "mobileNo", target = "phone")
})


IGNORE FIELD
=============

@Mapping(target = "password",
         ignore = true)


DATE FORMAT
===========

@Mapping(source = "dob",
         target = "birthDate",
         dateFormat = "dd-MM-yyyy")


LIST MAPPING
============

List<UserDTO> toDtoList(List<User> users);


NESTED OBJECT MAPPING
=====================

public class Address {
    private String city;
}

public class User {
    private Address address;
}

public class UserDTO {
    private String city;
}


@Mapping(source = "address.city",
         target = "city")


UPDATE EXISTING OBJECT
======================

@Mapping(target = "id", ignore = true)
void updateUser(@MappingTarget User user,
                UserDTO dto);



########################################################################################################################################################################

SPRING BOOT VALIDATION
======================

- Validation is used to validate request data.
- Mostly used on DTO/Model classes.
- Uses Jakarta Validation / Hibernate Validator.


COMMON VALIDATION ANNOTATIONS
=============================

1) @NotNull
------------
- Value should not be null.

@NotNull
private String name;


2) @NotEmpty
-------------
- Value should not be null and not empty.
- Works for String, List, Set, Map.

@NotEmpty
private String name;


3) @NotBlank
-------------
- String should not be null and not blank.
- Ignores spaces.

@NotBlank
private String name;


4) @Size
---------
- Defines min/max length.

@Size(min = 3, max = 20)
private String username;


5) @Min
--------
- Minimum numeric value.

@Min(18)
private int age;


6) @Max
--------
- Maximum numeric value.

@Max(60)
private int age;


7) @Email
----------
- Valid email format.

@Email
private String email;


8) @Pattern
------------
- Regex validation.

@Pattern(regexp = "[A-Z]{5}[0-9]{4}[A-Z]{1}")
private String panNo;


9) @Past
---------
- Date should be past date.

@Past
private Date dob;


10) @Future
------------
- Date should be future date.

@Future
private Date bookingDate;


11) @Positive
--------------
- Value must be positive.

@Positive
private double salary;


12) @Negative
--------------
- Value must be negative.

@Negative
private int loss;


13) @Digits
------------
- Controls integer and decimal digits.

@Digits(integer = 5, fraction = 2)
private double amount;


MODEL EXAMPLE
==============

public class UserDTO {

    @NotBlank(message = "Name is required")
    private String name;

    @Email(message = "Invalid email")
    private String email;

    @Min(value = 18,
         message = "Age must be above 18")
    private int age;
}


CONTROLLER VALIDATION
=====================

@PostMapping("/save")
public String saveUser(
        @Valid @RequestBody UserDTO dto) {

    return "Saved";
}


VALIDATION EXCEPTION
====================

MethodArgumentNotValidException

Occurs when validation fails.


BINDINGRESULT
==============

@PostMapping("/save")
public String saveUser(
        @Valid @RequestBody UserDTO dto,
        BindingResult result) {

    if(result.hasErrors()) {
        return "Validation Failed";
    }

    return "Success";
}


CUSTOM VALIDATION ANNOTATION
=============================

STEP 1 -> CREATE ANNOTATION
===========================

@Target(ElementType.FIELD)
@Retention(RetentionPolicy.RUNTIME)
@Constraint(validatedBy = PanValidator.class)

public @interface ValidPan {

    String message()
        default "Invalid PAN Number";

    Class<?>[] groups() default {};

    Class<? extends Payload>[] payload()
        default {};
}


STEP 2 -> CREATE VALIDATOR CLASS
================================

public class PanValidator
    implements ConstraintValidator<ValidPan,
                                   String> {

    @Override
    public boolean isValid(String value,
                           ConstraintValidatorContext context) {

        return value != null &&
               value.matches(
               "[A-Z]{5}[0-9]{4}[A-Z]{1}");
    }
}


STEP 3 -> USE CUSTOM ANNOTATION
================================

public class UserDTO {

    @ValidPan
    private String panNo;
}


